<?xml version="1.0" encoding="UTF-8"?>
<manifest>

    <remote name="gitlab"
        fetch="https://gitlab.com/" />
    
    <remote name="github-private"
        fetch="git@github.com:" />
    

    <!-- Device -->
    <project
        name="Shaddowalker-26/android_device_xiaomi_spes"
        path="device/xiaomi/spes"
        revision="sixteen-qpr2" />

    <!-- Vendor -->
    <project
        name="Shaddowalker-26/android_vendor_xiaomi_spes"
        path="vendor/xiaomi/spes"
        revision="sixteen-local" />

    <!-- Kernel -->
    <project name="Shaddowalker-26/Prebuilt_kernel_Lineage"
             path="device/xiaomi/spes-kernel"
             revision="main" />

    <!-- Hardware -->
    <project
        name="Shaddowalker-26/android_hardware_xiaomi"
        path="hardware/xiaomi"
        revision="sixteen-local" />

    <!-- XiaomiParts -->
    <project
        name="Shaddowalker-26/android_packages_apps_XiaomiParts"
        path="packages/apps/XiaomiParts"
        revision="sixteen-local" />
     
    <!--keys-->
    <project
    name="Shaddowalker-26/android-signing-keys"
    path="vendor/lineage-priv/keys"
    remote="github-private"
    revision="main" />
    
    <!-- Replace upstream Settings -->
    <remove-project name="LineageOS/android_packages_apps_Settings" />

    <project
        name="Shaddowalker-26/android_packages_apps_Settings"
        path="packages/apps/Settings"
        revision="lineage-23.2" />

    <!-- Replace frameworks/base -->
    <remove-project name="LineageOS/android_frameworks_base" />

    <project
        name="Shaddowalker-26/android_frameworks_base"
        path="frameworks/base"
        revision="lineage-23.2" />

   <!--Replace vendor -->
    <remove-project name="LineageOS/android_vendor_lineage" />
    
    <project 
        name="Shaddowalker-26/android_vendor_lineage"
             path="vendor/lineage"
             revision="lineage-23.2" />

    <!-- Pixel Lockscreen Clocks -->
    <project
        name="pixelos-aosp/proprietary_vendor_pixel_clocks"
        path="vendor/pixelos/pixel-clocks"
        remote="gitlab"
        revision="sixteen-qpr2" />

    <!--Omnijaw Weather -->
    <project
        name="shaddowalker-26/android_packages_services_Omnijaws"
        path="packages/services/OmniJaws"
        revision="16.0" />

    <!--SPES OTA -->
    <project
        name="Shaddowalker-26/Spes-ota"
        path="spes-ota"
        revision="main" />


</manifest>
